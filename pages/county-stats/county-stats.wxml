<!--pages/county-stats/county-stats.wxml-->
<view class="page-container">
  <!-- 年份选项卡 - 简约可滚动设计 -->
  <view class="year-scroll-container">
    <scroll-view class="year-scroll" scroll-x>
      <view class="year-scroll-content">
        <view 
          wx:for="{{yearTabs}}" 
          wx:key="index"
          class="scroll-year-tab {{item === currentYear ? 'active' : ''}}"
          bindtap="switchYear"
          data-year="{{item}}"
        >
          {{item}}
        </view>
      </view>
    </scroll-view>
    <view class="year-current">
      <text class="year-current-label">当前年份</text>
      <text class="year-current-value">{{currentYear}}</text>
    </view>
  </view>

  <!-- 播放控制 -->
  <view class="play-control-container">
    <view class="play-control-buttons">
      <button class="play-control-btn prev-btn" bindtap="prevYear">
        <text class="btn-icon">◀</text>
        <text class="btn-text">上一年</text>
      </button>
      
      <button class="play-control-btn play-btn {{isPlaying ? 'playing' : ''}}" bindtap="togglePlay">
        <text class="btn-icon">{{isPlaying ? '❚❚' : '▶'}}</text>
        <text class="btn-text">{{isPlaying ? '暂停' : '播放'}}</text>
      </button>
      
      <button class="play-control-btn next-btn" bindtap="nextYear">
        <text class="btn-text">下一年</text>
        <text class="btn-icon">▶</text>
      </button>
    </view>
    
    <view class="play-speed-control">
      <text class="speed-label">播放速度:</text>
      <view class="speed-options">
        <view 
          class="speed-option {{playSpeed === 500 ? 'active' : ''}}" 
          bindtap="changePlaySpeed" 
          data-speed="500"
        >快</view>
        <view 
          class="speed-option {{playSpeed === 1000 ? 'active' : ''}}" 
          bindtap="changePlaySpeed" 
          data-speed="1000"
        >中</view>
        <view 
          class="speed-option {{playSpeed === 2000 ? 'active' : ''}}" 
          bindtap="changePlaySpeed" 
          data-speed="2000"
        >慢</view>
      </view>
    </view>
    
    <view class="current-play-info">
      <text>当前播放年份: {{currentYear}}</text>
      <text wx:if="{{isPlaying}}" class="playing-indicator">● 播放中</text>
    </view>
  </view>

  <!-- 年度碳汇概览 -->
  <view class="overview-section">
    <view class="section-title">
      <text class="title-text">{{currentYear}}年碳汇年度概览</text>
      <text class="subtitle">全年月度数据统计汇总</text>
    </view>
    
    <view class="overview-cards">
      <view class="overview-card">
        <text class="card-icon">🗓️</text>
        <text class="card-title">数据月份</text>
        <text class="card-value">12个月</text>
      </view>
      <view class="overview-card">
        <text class="card-icon">🏙️</text>
        <text class="card-title">统计区县</text>
        <text class="card-value">{{countyStats.length}}个</text>
      </view>
      <view class="overview-card">
        <text class="card-icon">📈</text>
        <text class="card-title">平均碳汇</text>
        <text class="card-value">{{averageCarbon}}吨</text>
      </view>
      <view class="overview-card">
        <text class="card-icon">🏆</text>
        <text class="card-title">最高碳汇</text>
        <text class="card-value">{{maxCarbon}}吨</text>
      </view>
    </view>
  </view>

  <!-- 统计表格区域 -->
  <view class="stats-section">
    <view class="section-title">
      <text class="title-text">{{currentYear}}年区县碳汇统计</text>
      <text class="subtitle">单位: 吨/月（全年累计）</text>
    </view>
    
    <!-- 排序控件 -->
    <view class="sort-controls">
      <view 
        class="sort-btn {{sortField === 'name' ? 'active' : ''}}"
        bindtap="toggleSort"
        data-field="name"
      >
        区县名称
        <text class="sort-icon" wx:if="{{sortField === 'name'}}">
          {{sortOrder === 'asc' ? '↑' : '↓'}}
        </text>
      </view>
      <view 
        class="sort-btn {{sortField === 'value' ? 'active' : ''}}"
        bindtap="toggleSort"
        data-field="value"
      >
        碳汇总量
        <text class="sort-icon" wx:if="{{sortField === 'value'}}">
          {{sortOrder === 'asc' ? '↑' : '↓'}}
        </text>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-container">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 数据表格 -->
    <view wx:else class="stats-table">
      <view class="table-header">
        <view class="table-cell table-cell-name">区县</view>
        <view class="table-cell table-cell-value">碳汇总量</view>
        <view class="table-cell table-cell-rank">排名</view>
      </view>
      
      <scroll-view class="table-body" scroll-y>
        <block wx:for="{{countyStats}}" wx:key="name">
          <view class="table-row {{index % 2 === 0 ? 'even' : 'odd'}}">
            <view class="table-cell table-cell-name">{{item.name}}</view>
            <view class="table-cell table-cell-value {{item.value >= 0 ? 'positive' : 'negative'}}">
              {{item.value.toFixed(2)}}
            </view>
            <view class="table-cell table-cell-rank">
              {{index + 1}}
              <text class="rank-icon" wx:if="{{index < 3}}">🏆</text>
            </view>
          </view>
        </block>
        
        <view wx:if="{{countyStats.length === 0}}" class="empty-data">
          <text class="empty-text">暂无数据</text>
        </view>
      </scroll-view>
    </view>

    <!-- 统计摘要 -->
    <view class="stats-summary">
      <view class="summary-item">
        <text class="summary-label">区县数量</text>
        <text class="summary-value">{{countyStats.length}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">平均碳汇</text>
        <text class="summary-value">{{averageCarbon}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">最高碳汇</text>
        <text class="summary-value">{{maxCarbon}}</text>
      </view>
    </view>
  </view>

  <!-- 自然环保提示 -->
  <view class="eco-tips">
    <text class="eco-icon">🌿</text>
    <text class="eco-text">保护秦岭生态，共建绿色家园</text>
  </view>
</view>