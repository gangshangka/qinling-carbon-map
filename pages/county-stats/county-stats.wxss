/* pages/county-stats/county-stats.wxss - 高级环保设计 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  padding: 24rpx;
  color: #e6e6e6;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
}

/* 年份选项卡 - 高级设计 */
.year-tabs {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
  padding: 28rpx;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.year-tab {
  padding: 18rpx 36rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #a0aec0;
  border: 1.5rpx solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  text-align: center;
  min-width: 140rpx;
  position: relative;
  overflow: hidden;
}

.year-tab::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.1) 0%, rgba(46, 125, 50, 0.1) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.year-tab.active {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  border-color: transparent;
  transform: translateY(-2rpx);
  box-shadow: 
    0 8rpx 24rpx rgba(46, 125, 50, 0.4),
    0 4rpx 8rpx rgba(46, 125, 50, 0.2);
}

.year-tab.active::before {
  opacity: 1;
}

.year-tab:not(.active):active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.98);
}

/* 轮播图区域 - 高级设计 */
.swiper-section {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 
    0 16rpx 48rpx rgba(0, 0, 0, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 36rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.section-title {
  display: flex;
  flex-direction: column;
}

.title-text {
  font-size: 38rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
  letter-spacing: 0.5rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #a0aec0;
  font-weight: 400;
  letter-spacing: 0.3rpx;
}

.section-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.action-text {
  font-size: 26rpx;
  color: #a0aec0;
}

.action-icon {
  font-size: 32rpx;
  color: #4CAF50;
}

/* 图片容器 */
.image-container {
  position: relative;
  height: 560rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(0, 0, 0, 0.3);
  margin-bottom: 32rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.5),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.base-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  opacity: 0.4;
  filter: grayscale(0.2) brightness(0.9);
  z-index: 1;
}

.image-swiper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  border-radius: 20rpx;
  overflow: hidden;
}

.swiper-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  filter: drop-shadow(0 8rpx 24rpx rgba(0, 0, 0, 0.5));
}

.swiper-item:active .swiper-image {
  transform: scale(0.97);
}

.image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.4) 50%, transparent 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.month-label {
  font-size: 34rpx;
  font-weight: 700;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.8);
}

.compare-label {
  font-size: 26rpx;
  color: #a0aec0;
  font-weight: 400;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.8);
}

.swiper-info {
  display: flex;
  justify-content: space-between;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.info-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-icon {
  font-size: 28rpx;
  color: #4CAF50;
}

.info-text {
  font-size: 26rpx;
  color: #a0aec0;
}

/* 统计表格区域 */
.stats-section {
  background: rgba(255, 255, 255, 0.05);
  backdrop-filter: blur(20rpx);
  border-radius: 28rpx;
  padding: 36rpx;
  margin-bottom: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 
    0 16rpx 48rpx rgba(0, 0, 0, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.stats-section .section-title {
  margin-bottom: 32rpx;
}

/* 排序控件 */
.sort-controls {
  display: flex;
  gap: 20rpx;
  margin-bottom: 36rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.sort-btn {
  flex: 1;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #a0aec0;
  text-align: center;
  border: 1.5rpx solid rgba(255, 255, 255, 0.1);
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.sort-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.1) 0%, rgba(46, 125, 50, 0.1) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.sort-btn.active {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  border-color: transparent;
  box-shadow: 
    0 6rpx 20rpx rgba(46, 125, 50, 0.3),
    0 3rpx 6rpx rgba(46, 125, 50, 0.2);
}

.sort-btn.active::before {
  opacity: 1;
}

.sort-btn:not(.active):active {
  background: rgba(255, 255, 255, 0.1);
  transform: scale(0.98);
}

.sort-icon {
  font-size: 24rpx;
  font-weight: 700;
}

/* 加载状态 */
.loading-container {
  padding: 120rpx;
  text-align: center;
}

.loading-text {
  font-size: 32rpx;
  color: #4CAF50;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* 表格样式 */
.stats-table {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  margin-bottom: 32rpx;
}

.table-header {
  display: flex;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.2) 0%, rgba(46, 125, 50, 0.2) 100%);
  color: white;
  font-weight: 600;
  font-size: 30rpx;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.table-cell {
  flex: 1;
  text-align: center;
  padding: 0 12rpx;
}

.table-cell-name {
  flex: 2;
  text-align: left;
}

.table-cell-value {
  flex: 1.5;
}

.table-cell-rank {
  flex: 0.8;
}

.table-body {
  max-height: 800rpx;
}

.table-row {
  display: flex;
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  transition: all 0.2s ease;
  position: relative;
}

.table-row::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.03) 0%, rgba(46, 125, 50, 0.03) 100%);
  opacity: 0;
  transition: opacity 0.2s ease;
}

.table-row.even {
  background: rgba(255, 255, 255, 0.02);
}

.table-row.odd {
  background: rgba(255, 255, 255, 0.01);
}

.table-row:active {
  background: rgba(255, 255, 255, 0.05);
}

.table-row:active::before {
  opacity: 1;
}

.table-cell-name {
  color: #ffffff;
  font-weight: 500;
}

.table-cell-value.positive {
  color: #4CAF50;
  font-weight: 600;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.5);
}

.table-cell-value.negative {
  color: #f44336;
  font-weight: 600;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.5);
}

.table-cell-rank {
  color: #a0aec0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.rank-icon {
  font-size: 32rpx;
}

.empty-data {
  padding: 120rpx;
  text-align: center;
}

.empty-text {
  font-size: 32rpx;
  color: #a0aec0;
  font-weight: 500;
}

/* 统计摘要 */
.stats-summary {
  display: flex;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  padding: 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  margin-top: 32rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(0, 0, 0, 0.3),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #a0aec0;
  font-weight: 500;
  letter-spacing: 0.3rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

/* 环保提示 */
.eco-tips {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.2) 0%, rgba(46, 125, 50, 0.2) 100%);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 48rpx;
  text-align: center;
  color: white;
  font-size: 34rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  margin-top: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  box-shadow: 
    0 16rpx 48rpx rgba(0, 0, 0, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.1);
}

.eco-icon {
  font-size: 72rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(0, 0, 0, 0.5));
}

.eco-text {
  font-weight: 600;
  letter-spacing: 0.5rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

/* 响应式调整 */
@media (max-width: 750rpx) {
  .section-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 20rpx;
  }
  
  .section-actions {
    align-self: flex-end;
  }
  
  .year-tabs {
    gap: 12rpx;
  }
  
  .year-tab {
    padding: 16rpx 28rpx;
    font-size: 26rpx;
    min-width: 120rpx;
  }
  
  .image-container {
    height: 480rpx;
  }
  
  .stats-summary {
    flex-direction: column;
    gap: 32rpx;
  }
  
  .summary-item {
    flex-direction: row;
    justify-content: space-between;
    width: 100%;
  }
  
  .summary-label {
    margin-bottom: 0;
  }
  
  .swiper-info {
    flex-direction: column;
    gap: 20rpx;
  }
}