<view class="container">

  
  <!-- 精简模式切换 -->
  <view class="mode-switch">
    <view class="mode-tabs">
      <view 
        class="mode-tab {{chartMode === 'annual' ? 'active' : ''}}" 
        bindtap="switchChartMode" 
        data-mode="annual"
      >
        年度统计
      </view>
      <view 
        class="mode-tab {{chartMode === 'county' ? 'active' : ''}}" 
        bindtap="switchChartMode" 
        data-mode="county"
      >
        县级排名
      </view>
    </view>
  </view>
  
  <!-- 紧凑播放控制 - 仅在县级排名模式下显示 -->
  <view class="compact-play-control" wx:if="{{chartMode === 'county'}}">
    <view class="compact-control-row">
      <!-- 播放控制按钮 -->
      <view class="compact-buttons">
        <button class="compact-btn prev-btn" bindtap="prevYear">
          <text class="compact-btn-icon">◀</text>
        </button>
        
        <button class="compact-btn play-btn {{isPlaying ? 'playing' : ''}}" bindtap="togglePlay">
          <text class="compact-btn-icon">{{isPlaying ? '❚❚' : '▶'}}</text>
        </button>
        
        <button class="compact-btn next-btn" bindtap="nextYear">
          <text class="compact-btn-icon">▶</text>
        </button>
      </view>
      
      <!-- 速度控制 -->
      <view class="compact-speed-control">
        <text class="compact-speed-label">速度</text>
        <view class="compact-speed-options">
          <view 
            class="compact-speed-option {{playSpeed === 1000 ? 'active' : ''}}" 
            bindtap="changePlaySpeed" 
            data-speed="1000"
          >快</view>
          <view 
            class="compact-speed-option {{playSpeed === 2000 ? 'active' : ''}}" 
            bindtap="changePlaySpeed" 
            data-speed="2000"
          >中</view>
          <view 
            class="compact-speed-option {{playSpeed === 3000 ? 'active' : ''}}" 
            bindtap="changePlaySpeed" 
            data-speed="3000"
          >慢</view>
        </view>
      </view>
    </view>
    
  </view>
  
  <!-- 图表容器 -->
  <view class="chart-container">
    <ec-canvas 
      id="carbon-chart" 
      canvas-id="carbon-chart" 
      echarts="{{ echarts }}"
      ec="{{ ec }}" 
      style="width: 100%; height: 100%;"
    ></ec-canvas>
  </view>
  
  <!-- 当前数据项显示 -->
  <view class="data-display">
    <view wx:if="{{chartMode === 'annual'}}" class="current-item">
      <text class="current-value">{{ annualData && annualData[currentYearIndex] ? annualData[currentYearIndex].year : '' }}</text>
      <text class="value-text">年</text>
      <view class="item-details">
        <text>碳汇量: {{ annualData && annualData[currentYearIndex] ? annualData[currentYearIndex].value.toFixed(2) : '0.00' }} 吨</text>
        <text>同比增长: {{ annualData && annualData[currentYearIndex] ? annualData[currentYearIndex].change.toFixed(2) : '0.00' }}%</text>
      </view>
    </view>
    <view wx:if="{{chartMode === 'county'}}" class="current-item">
      <text class="current-value">{{ countyData && countyData[currentCountyIndex] ? countyData[currentCountyIndex].county : '' }}</text>
      <text class="value-text">县</text>
      <view class="item-details">
        <text>碳汇量: {{ countyData && countyData[currentCountyIndex] ? countyData[currentCountyIndex].value.toFixed(2) : '0.00' }} 吨</text>
        <text>排名: 第{{ countyData && countyData[currentCountyIndex] ? countyData[currentCountyIndex].rank : '0' }}名</text>
      </view>
    </view>


  </view>
  

  
  <!-- 说明 -->
  <view class="description">
    <text>数据来源：秦岭碳汇监测</text>
    <text>单位：吨碳当量</text>
    <text>更新日期: {{updateTime}}</text>
  </view>
</view>