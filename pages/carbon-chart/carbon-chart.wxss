.container {
  padding: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
}

.title {
  font-size: 36rpx;
  color: white;
  text-align: center;
  padding: 30rpx 0;
  font-weight: bold;
}

/* 模式切换 */
.mode-switch {
  margin-bottom: 30rpx;
}

.mode-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50rpx;
  padding: 8rpx;
  margin: 0 40rpx;
  backdrop-filter: blur(10px);
}

.mode-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.mode-tab.active {
  background: white;
  color: #667eea;
  font-weight: bold;
  box-shadow: 0 5rpx 15rpx rgba(0,0,0,0.1);
}

.chart-container {
  width: 100%;
  height: 750rpx;
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.2);
}

/* 数据项显示 */
.data-display {
  text-align: center;
  margin: 40rpx 0;
}

.current-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.current-value {
  font-size: 80rpx;
  color: white;
  font-weight: bold;
  text-shadow: 0 5rpx 15rpx rgba(0,0,0,0.3);
}

.value-text {
  font-size: 36rpx;
  color: white;
  margin-left: 10rpx;
}

.item-details {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.item-details .detail-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.1);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  backdrop-filter: blur(10px);
}



.description {
  margin-top: 40rpx;
  text-align: center;
  color: rgba(255,255,255,0.8);
  font-size: 24rpx;
  line-height: 1.5;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}