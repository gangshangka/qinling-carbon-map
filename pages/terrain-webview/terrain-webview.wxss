/* pages/terrain-webview/terrain-webview.wxss */
.container {
  width: 100%;
  height: 100vh;
  position: relative;
}

/* 选项卡样式 */
.tab-bar {
  display: flex;
  background: linear-gradient(90deg, #0a1931 0%, #1a3c79 100%);
  height: 100rpx;
  position: relative;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.7);
  font-size: 32rpx;
  font-weight: bold;
  transition: all 0.3s ease;
  border-bottom: 8rpx solid transparent;
}

.tab-item.active {
  color: white;
  border-bottom-color: #00dbde;
  background: rgba(0, 219, 222, 0.1);
}

.tab-text {
  padding: 10rpx 0;
}

/* 内容区域 */
.content-view {
  width: 100%;
  height: calc(100vh - 100rpx);
  overflow-y: auto;
  background: #f5f7fa;
}

/* 地形图加载提示 */
.loading-tip {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #0a1931, #1a3c79);
  z-index: 1;
}

.loading-text {
  color: #00dbde;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
}

/* ========== 3D柱状图样式 ========== */
/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 400rpx;
  background: white;
  border-radius: 20rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #666;
}

/* 错误提示 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  background: white;
  border-radius: 20rpx;
  margin: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.error-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 32rpx;
  color: #f44336;
  margin-bottom: 30rpx;
  line-height: 1.4;
}

.refresh-btn {
  background: #4CAF50;
  color: white;
  border: none;
  padding: 20rpx 40rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

/* 统计信息卡片 */
.stats-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  text-align: center;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-item {
  background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
  border-radius: 15rpx;
  padding: 25rpx;
  text-align: center;
  border: 2rpx solid #e0e0e0;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
  line-height: 1.3;
}

/* 图表容器 */
.chart-container {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  height: 600rpx;
  /* 秦岭地形图背景效果 */
  background-image: 
    linear-gradient(135deg, rgba(139, 195, 74, 0.1) 0%, rgba(76, 175, 80, 0.1) 100%),
    repeating-linear-gradient(45deg, transparent, transparent 10rpx, rgba(139, 195, 74, 0.05) 10rpx, rgba(139, 195, 74, 0.05) 20rpx);
  position: relative;
  overflow: hidden;
}

/* 地形图轮廓效果 */
.chart-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: 
    radial-gradient(circle at 30% 30%, rgba(46, 125, 50, 0.05) 0%, transparent 50%),
    radial-gradient(circle at 70% 70%, rgba(139, 195, 74, 0.05) 0%, transparent 50%),
    radial-gradient(circle at 50% 50%, rgba(76, 175, 80, 0.05) 0%, transparent 60%);
  pointer-events: none;
  z-index: 0;
}

.chart-canvas {
  width: 100%;
  height: 100%;
  position: relative;
  z-index: 1;
}

/* 控制面板 */
.control-panel {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.control-section {
  margin-bottom: 40rpx;
}

.control-section:last-child {
  margin-bottom: 0;
}

.control-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.button-group {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15rpx;
}

.control-btn {
  background: #f8f9fa;
  color: #333;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 15rpx 5rpx;
  font-size: 26rpx;
  transition: all 0.3s ease;
}

.control-btn.active {
  background: #4CAF50;
  color: white;
  border-color: #4CAF50;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.3);
}

/* 颜色按钮 */
.color-buttons {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
}

.color-btn {
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 20rpx 10rpx;
  font-size: 24rpx;
  color: white;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s ease;
}

.color-btn.active {
  border-color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  transform: translateY(-2rpx);
}

/* 图例说明 */
.legend-section {
  background: #f8f9fa;
  border-radius: 15rpx;
  padding: 25rpx;
  margin-top: 20rpx;
}

.legend-items {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.legend-color {
  width: 30rpx;
  height: 30rpx;
  border-radius: 6rpx;
  border: 2rpx solid white;
  box-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.legend-text {
  font-size: 26rpx;
  color: #555;
}

/* 操作提示 */
.hint-section {
  background: #e8f5e8;
  border-radius: 15rpx;
  padding: 25rpx;
  margin-top: 20rpx;
  border-left: 8rpx solid #4CAF50;
}

.hint-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 15rpx;
}

.hint-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.5;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin: 30rpx 20rpx;
}

.action-btn {
  flex: 1;
  padding: 25rpx;
  border-radius: 15rpx;
  font-size: 30rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  transition: all 0.3s ease;
}

.action-btn.refresh {
  background: linear-gradient(90deg, #2196F3 0%, #21CBF3 100%);
  color: white;
}

.action-btn.back {
  background: linear-gradient(90deg, #757575 0%, #9E9E9E 100%);
  color: white;
}

.action-btn.terrain {
  background: linear-gradient(90deg, #FF9800 0%, #FFB74D 100%);
  color: white;
}

.action-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

/* 响应式调整 */
@media (max-width: 768px) {
  .stats-grid {
    grid-template-columns: 1fr;
  }
  
  .button-group {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .color-buttons {
    grid-template-columns: 1fr;
  }
  
  .legend-items {
    grid-template-columns: 1fr;
  }
  
  .action-buttons {
    flex-direction: column;
  }
}