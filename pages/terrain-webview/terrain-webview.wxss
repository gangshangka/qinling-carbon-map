.container {
  padding: 30rpx;
  background: linear-gradient(135deg, #0a1931, #1a3c79);
  min-height: 100vh;
  color: #fff;
}
.text-preview {
  text-align: center;
  padding: 60rpx 0;
  margin-bottom: 30rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
}
.preview-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #00dbde;
  margin-bottom: 20rpx;
}
.preview-desc {
  font-size: 28rpx;
  opacity: 0.8;
}
.stats {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-bottom: 40rpx;
}
.stat-card {
  flex: 1;
  min-width: 150rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 12rpx;
  padding: 16rpx 0;
  text-align: center;
  border: 1rpx solid rgba(255,255,255,0.2);
}
.stat-title {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}
.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #00dbde;
  display: block;
}
.open-btn {
  background: linear-gradient(135deg, #00dbde, #fc00ff);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.hint {
  text-align: center;
  font-size: 24rpx;
  opacity: 0.7;
}