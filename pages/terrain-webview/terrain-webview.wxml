<view class="container">
  <view class="text-preview">
    <view class="preview-title">🌲 秦岭碳汇3D柱状图</view>
    <view class="preview-desc">月度碳汇数据 · 交互式可视化</view>
  </view>

  <view class="stats">
    <view class="stat-card">
      <text class="stat-title">县区数量</text>
      <text class="stat-value">24</text>
    </view>
    <view class="stat-card">
      <text class="stat-title">平均碳汇</text>
      <text class="stat-value">238.54</text>
    </view>
    <view class="stat-card">
      <text class="stat-title">最高碳汇</text>
      <text class="stat-value">357.93</text>
    </view>
    <view class="stat-card">
      <text class="stat-title">最低碳汇</text>
      <text class="stat-value">-89.47</text>
    </view>
  </view>

  <button class="open-btn" bindtap="openWebView">在浏览器中打开3D交互版</button>
  <view class="hint">点击按钮复制链接，在手机浏览器中粘贴打开</view>
</view>