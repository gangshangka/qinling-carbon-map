<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 影像显示区域 -->
  <view class="image-viewer">
    <!-- 占位图 - 始终显示2012年1月图片 -->
    <image
      src="{{placeholderImageUrl}}"
      mode="aspectFit"
      class="placeholder-image"
      style="transform: scale({{imageScale}}); transform-origin: center center; opacity: {{imageOpacity}};"
    />
    
    <!-- 目标图 - 加载完成后显示 -->
    <image
      src="{{currentImageUrl}}"
      mode="aspectFit"
      bindload="onImageLoad"
      binderror="onImageError"
      class="target-image {{imageLoaded ? 'visible' : 'hidden'}}"
      style="transform: scale({{imageScale}}); transform-origin: center center; opacity: {{imageOpacity}};"
    />
  </view>

  <!-- 控制面板 -->
  <view class="control-panel">
    <!-- 年份选项卡 -->
    <view class="slider-section">
      <view class="year-header">
        <text class="year-label">年份选择</text>
        <text class="current-year">{{currentYear}} 年</text>
        <button size="mini" bindtap="jumpToYear">快速跳转</button>
      </view>
      
      <view class="year-tabs">
        <block wx:for="{{yearTabs}}" wx:key="index">
          <view 
            class="year-tab {{currentYear === item ? 'active' : ''}}" 
            bindtap="switchYear" 
            data-year="{{item}}"
          >
            {{item}}年
          </view>
        </block>
      </view>
      
      <view class="year-range">
        <text>{{minYear}}</text>
        <text class="range-label">点击选项卡切换年份</text>
        <text>{{maxYear}}</text>
      </view>
    </view>
    

  </view>

    <!-- 数据图表 -->
    <view class="chart-panel">
      <view class="chart-header">
        <text>碳汇月度统计</text>
        <view class="chart-buttons">
          <button size="mini" bindtap="navigateToCarbonChart">碳汇统计</button>
          <button size="mini" bindtap="navigateToCurveStatistics">曲线统计</button>
          <button size="mini" bindtap="navigateToCountyStats">区县统计</button>
          <button size="mini" bindtap="showSystemInfo">系统信息</button>
        </view>
      </view>
    
    <view class="chart-container">
  <canvas 
    id="monthlyChart"
    canvas-id="monthlyChart" 
    type="2d"
    style="width: 100%; height: 100%;"
  ></canvas>
</view>
    
    <view class="chart-footer">
      <text>注: 当前为模拟数据，可替换为真实碳汇数据</text>
    </view>
  </view>
</view>