/* pages/index/index.wxss */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  font-smooth: always;
  position: relative;
}

/* 影像查看器 */
.image-viewer {
  flex: none;
  position: relative;
  background: #ffffff;
  overflow: hidden;
  width: 100%;
  height: 35vh;
  margin-top: -88rpx;
  border: none;
}

.placeholder-image,
.target-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  margin: 0;
  padding: 0;
  transform-origin: center center;
  transition: transform 0.3s ease, opacity 0.3s ease;
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
  image-rendering: pixelated;
  -ms-interpolation-mode: nearest-neighbor;
}

.placeholder-image {
  opacity: 1;
  z-index: 1;
}

.target-image {
  opacity: 0;
  z-index: 2;
}

.target-image.visible {
  opacity: 1;
}

.target-image.hidden {
  opacity: 0;
}

/* 加载状态 */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e0e0e0;
  border-top: 6rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-overlay text {
  color: #333;
  font-size: 28rpx;
  margin-bottom: 15rpx;
  display: block;
  text-align: center;
}

.progress-text {
  color: #4CAF50;
  font-size: 24rpx;
  margin-top: 10rpx;
}

/* 信息覆盖层 */
.info-overlay {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  right: 30rpx;
  z-index: 10;
}

.info-card {
  background: rgba(0, 0, 0, 0.75);
  border-radius: 16rpx;
  padding: 30rpx;
  color: white;
}

.info-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.info-subtitle {
  display: block;
  font-size: 26rpx;
  color: #52c41a;
  margin-bottom: 20rpx;
}

.info-details text {
  display: block;
  font-size: 24rpx;
  color: #cccccc;
  margin-bottom: 8rpx;
}

/* 控制按钮 */
.control-buttons {
  position: absolute;
  bottom: 30rpx;
  right: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  z-index: 10;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.7);
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
  padding: 0;
  margin: 0;
}

.control-btn::after {
  border: none;
}

.control-btn text {
  font-size: 32rpx;
  font-weight: bold;
}

/* 控制面板 */
.control-panel {
  background: rgba(255, 255, 255, 0.95);
  padding: 15rpx 20rpx; /* 进一步压缩内边距 */
  backdrop-filter: blur(5px);
}

.year-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.year-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.current-year {
  font-size: 38rpx;
  font-weight: bold;
  color: #4CAF50;
}

/* 年份选项卡样式 */
.year-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 30rpx;
  padding: 6rpx;
  margin: 15rpx 0;
  backdrop-filter: blur(5px);
  border: 1rpx solid rgba(76, 175, 80, 0.3);
  min-height: 80rpx; /* 压缩最小高度 */
}

.year-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0; /* 压缩内边距 */
  font-size: 26rpx; /* 减小字体 */
  font-weight: 500;
  color: #333333;
  border-radius: 25rpx;
  transition: all 0.3s ease;
  background: rgba(255, 255, 255, 0.8);
  margin: 0 3rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.year-tab.active {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  font-weight: bold;
  box-shadow: 0 3rpx 10rpx rgba(76, 175, 80, 0.3);
  font-size: 28rpx; /* 激活状态字体略大 */
}

.year-range {
  display: flex;
  justify-content: space-between;
  margin-top: 15rpx;
  font-size: 26rpx;
  color: #666;
}

.range-label {
  color: #999;
  font-size: 24rpx;
}

/* 预加载状态 */
.preload-status {
  margin-top: 15rpx;
  padding: 15rpx;
  background: #f0f9ff;
  border-radius: 10rpx;
}

.preload-status text {
  display: block;
  font-size: 22rpx;
  color: #1890ff;
  margin-bottom: 10rpx;
}

.progress-bar {
  height: 6rpx;
  background: #e6f7ff;
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #1890ff);
  transition: width 0.3s ease;
}

/* 图表面板 */
.chart-panel {
  background: white;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.chart-header text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.chart-buttons {
  display: flex;
  gap: 15rpx;
}

.chart-buttons button {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  line-height: 1.2;
  border-radius: 8rpx;
  background: #f0f2f5;
  color: #333;
  border: none;
}

.chart-buttons button::after {
  border: none;
}

.chart-buttons button:active {
  background: #e6e8eb;
}

.chart-container {
  width: 100%;
  height: 550rpx;          /* 可继续调大 */
  background: #fafafa;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  overflow: hidden;        /* 防止内容溢出 */
  box-sizing: border-box;
}

.chart-footer {
  margin-top: 20rpx;
  text-align: center;
}

.chart-footer text {
  font-size: 22rpx;
  color: #999;
  font-style: italic;
}

/* 错误提示样式 */
.error-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 90;
}

.error-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  max-width: 80%;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  border: 2rpx solid #ff4d4f;
}

.error-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 30rpx;
}

.error-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-bottom: 20rpx;
}

.error-message {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.error-hint {
  display: block;
  font-size: 26rpx;
  color: #666;
  font-style: italic;
}