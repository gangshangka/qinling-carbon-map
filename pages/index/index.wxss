  font-weight: 700;
  color: white;
}

/* 预加载状态 */
.preload-status {
  margin-top: 15rpx;
  padding: 15rpx;
  background: #f0f9ff;
  border-radius: 10rpx;
}

.preload-status text {
  display: block;
  font-size: 22rpx;
  color: #1890ff;
  margin-bottom: 10rpx;
}

.progress-bar {
  height: 6rpx;
  background: #e6f7ff;
  border-radius: 3rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a, #1890ff);
  transition: width 0.3s ease;
}

/* 图表面板 */
.chart-panel {
  background: white;
  margin: 5rpx 12rpx 12rpx 12rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.chart-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 8rpx;
  gap: 8rpx;
}

.chart-header text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.chart-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  justify-content: flex-start;
}

.chart-buttons button {
  font-size: 24rpx;
  padding: 10rpx 18rpx;
  line-height: 1.3;
  border-radius: 6rpx;
  background: #f0f2f5;
  color: #333;
  border: none;
  flex: 0 0 auto;
  min-width: 0;
  white-space: nowrap;
  font-weight: 500;
}

.chart-buttons button::after {
  border: none;
}

.chart-buttons button:active {
  background: #e6e8eb;
}

.chart-container {
  width: 100%;
  height: 380rpx;          /* 进一步调低高度以避免遮挡导航栏 */
  background: #fafafa;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  overflow: hidden;        /* 防止内容溢出 */
  box-sizing: border-box;
  position: relative;
  z-index: 1;
}

.chart-footer {
  margin-top: 12rpx;
  text-align: center;
}

.chart-footer text {
  font-size: 22rpx;
  color: #999;
  font-style: italic;
}

/* 错误提示样式 */
.error-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 90;
}

.error-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  max-width: 80%;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  border: 2rpx solid #ff4d4f;
}

.error-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 30rpx;
}

.error-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-bottom: 20rpx;
}

.error-message {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.4;
}

.error-hint {
  display: block;
  font-size: 26rpx;
  color: #666;
  font-style: italic;
}

/* 底部导航栏 */
.bottom-navbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 1000;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  padding: 15rpx 0;
  transition: all 0.2s ease;
  border-radius: 8rpx;
}

.nav-item:active {
  background: rgba(76, 175, 80, 0.05);
  transform: translateY(-2rpx);
}

.nav-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
  line-height: 1;
}

.nav-text {
  font-size: 20rpx;
  color: #333;
  font-weight: 500;
  white-space: nowrap;
}



