/* pages/index/index.wxss - 修复版本 */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  margin: 0;
  padding: 0 0 120rpx 0; /* 为底部导航栏留出空间 */
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  font-smooth: always;
  position: relative;
}

/* 影像查看器 */
.image-viewer {
  flex: none;
  position: relative;
  background: #ffffff;
  overflow: hidden;
  width: 100%;
  height: 32vh;
  margin-top: 0;
  border: none;
}

.placeholder-image,
.target-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  margin: 0;
  padding: 0 0 120rpx 0; /* 为底部导航栏留出空间 */
  transform-origin: center center;
  transition: none;
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
  image-rendering: pixelated;
  -ms-interpolation-mode: nearest-neighbor;
}

.placeholder-image {
  opacity: 1;
  z-index: 1;
}

.target-image {
  opacity: 0;
  z-index: 2;
}

.target-image.visible {
  opacity: 1;
}

.target-image.hidden {
  opacity: 0;
}

/* 控制面板与图表整合容器 */
.control-chart-container {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin: 12rpx;
}

/* 控制面板调整 */
.control-panel {
  background: rgba(255, 255, 255, 0.95);
  padding: 16rpx;
  backdrop-filter: blur(10px);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.selection-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.1);
}

.selection-header-left {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.selection-header-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.selection-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.current-selection {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
}

/* 时间选择行样式 - 年份和月份并排 */
.time-selection-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.time-selector {
  flex: 1;
  position: relative;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 249, 250, 0.95) 100%);
  border-radius: 10rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.15);
  padding: 12rpx 14rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
  transition: all 0.1s cubic-bezier(0.4, 0, 0.2, 1);
}

.time-selector:active {
  background: linear-gradient(135deg, rgba(248, 249, 250, 0.95) 0%, rgba(233, 236, 239, 0.95) 100%);
  transform: translateY(1rpx);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* 月份选择器标签带下拉按钮 */
.month-section-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.month-dropdown-btn {
  padding: 6rpx 12rpx;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.1) 0%, rgba(46, 125, 50, 0.1) 100%);
  border-radius: 6rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.1s cubic-bezier(0.4, 0, 0.2, 1);
}

.month-dropdown-btn:active {
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.2) 0%, rgba(46, 125, 50, 0.2) 100%);
  transform: translateY(1rpx);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

.month-dropdown-icon {
  font-size: 18rpx;
  color: #4CAF50;
  font-weight: bold;
  transition: transform 0.1s ease;
}

.month-dropdown-btn.active .month-dropdown-icon {
  transform: rotate(180deg);
}

/* 选中值显示样式 */
.selected-value-display {
  margin-top: 8rpx;
  padding: 12rpx 16rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 8rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.1s cubic-bezier(0.4, 0, 0.2, 1);
}

.selected-value-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #4CAF50;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

/* 月份选择器弹窗 */
.month-picker-panel {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 10003;
  opacity: 0;
  visibility: hidden;
  transition: all 0.1s cubic-bezier(0.4, 0, 0.2, 1);
}

.month-picker-panel.show {
  opacity: 1;
  visibility: visible;
}

.month-picker-panel.hide {
  opacity: 0;
  visibility: hidden;
}

.month-picker-content {
  background: white;
  border-radius: 12rpx;
  width: 90%;
  max-width: 700rpx;
  max-height: 85vh;
  overflow: auto;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.month-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
}

.month-picker-title {
  font-size: 28rpx;
  font-weight: 700;
}

.month-picker-close {
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
  color: white;
  opacity: 0.9;
}

.month-picker-close:active {
  opacity: 0.7;
}

.month-picker-options {
  padding: 20rpx;
}

.month-options-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: minmax(80rpx, auto);
  gap: 12rpx;
}

.year-options-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  grid-auto-rows: minmax(80rpx, auto);
  gap: 12rpx;
}

.year-option {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 8rpx;
  background: #f8f9fa;
  transition: all 0.1s ease;
}

.year-option:active {
  background: #e9ecef;
}

.year-option.selected {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.year-option-text {
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.2;
}

.year-option.selected .year-option-text {
  font-weight: 700;
  color: white;
}

.year-option-checkmark {
  font-size: 20rpx;
  font-weight: 700;
  color: white;
  margin-top: 4rpx;
}

.month-option {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 8rpx;
  background: #f8f9fa;
  transition: all 0.1s ease;
  aspect-ratio: 1;
}

.month-option:active {
  background: #e9ecef;
}

.month-option.selected {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.month-option-text {
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  line-height: 1.2;
}

.month-option.selected .month-option-text {
  font-weight: 700;
  color: white;
}

.month-option-checkmark {
  font-size: 20rpx;
  font-weight: 700;
  color: white;
  margin-top: 4rpx;
}

/* 图表面板调整 */
.chart-panel {
  background: white;
  padding: 16rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.chart-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  gap: 8rpx;
}

.chart-header text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  letter-spacing: 0.5rpx;
}

.chart-year-display {
  font-size: 28rpx;
  font-weight: 600;
  color: #4CAF50;
  background: rgba(76, 175, 80, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.2);
}

/* 图表容器高分辨率优化 */
.chart-container {
  width: 100%;
  height: 400rpx;
  background: #fafafa;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  overflow: hidden;
  box-sizing: border-box;
  position: relative;
  transition: z-index 0.3s ease;
}

.chart-container.hidden {
  z-index: -1;
  /* 保持完全可见，仅降低层级 */
}



/* 自动播放按钮 */
.auto-play-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  line-height: 1.3;
  border-radius: 6rpx;
  background: #f0f2f5;
  color: #333;
  border: none;
  flex-shrink: 0;
  font-weight: 500;
}

.auto-play-btn.active {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  font-weight: bold;
  border-color: transparent;
  box-shadow: 0 3rpx 8rpx rgba(76, 175, 80, 0.3);
}

.auto-play-btn::after {
  border: none;
}

.auto-play-status {
  font-size: 22rpx;
  color: #666;
  flex: 1;
  text-align: right;
  font-weight: 500;
}

/* 上传图片状态提示 */
.upload-status-tip {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.9) 0%, rgba(46, 125, 50, 0.9) 100%);
  color: white;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  z-index: 50;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  opacity: 0;
  transform: translateY(-20rpx);
  visibility: hidden;
  transition: all 0.3s ease;
}

.upload-status-tip.show {
  opacity: 1;
  transform: translateY(0);
  visibility: visible;
}

.upload-status-tip.hide {
  opacity: 0;
  transform: translateY(-20rpx);
  visibility: hidden;
}

.upload-status-icon {
  font-size: 24rpx;
}

.upload-status-text {
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
}

/* 图片预加载进度条样式 */
.preload-progress-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.preload-progress-content {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 70%;
  max-width: 500rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.2);
  text-align: center;
}

.preload-progress-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
}

.preload-progress-bar {
  width: 100%;
  height: 24rpx;
  background: #f0f2f5;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.preload-progress-inner {
  height: 100%;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 12rpx;
  transition: width 0.1s ease;
}

.preload-progress-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #4CAF50;
  display: block;
  margin-bottom: 20rpx;
}

.preload-progress-details {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  display: block;
}

/* 底部导航栏 */
.bottom-navbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: white;
  display: flex;
  align-items: center;
  justify-content: space-around;
  border-top: 1rpx solid rgba(0, 0, 0, 0.1);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 1000;
  padding: 0 20rpx;
  box-sizing: border-box;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 100%;
  padding: 15rpx 0;
  transition: all 0.1s ease;
  border-radius: 8rpx;
}

.nav-item:active {
  background: rgba(76, 175, 80, 0.05);
  transform: translateY(-2rpx);
}

.nav-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
  line-height: 1;
}

.nav-text {
  font-size: 20rpx;
  color: #333;
  font-weight: 500;
  white-space: nowrap;
}