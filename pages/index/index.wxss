/* pages/index/index.wxss */
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  margin: 0;
  padding: 0 0 120rpx 0; /* 为底部导航栏留出空间 */
  box-sizing: border-box;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  font-smooth: always;
  position: relative;
}

/* 影像查看器 */
.image-viewer {
  flex: none;
  position: relative;
  background: #ffffff;
  overflow: hidden;
  width: 100%;
  height: 32vh;
  margin-top: 0;
  border: none;
}

.placeholder-image,
.target-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  margin: 0;
  padding: 0;
  transform-origin: center center;
  transition: transform 0.3s ease, opacity 0.3s ease;
  image-rendering: -webkit-optimize-contrast;
  image-rendering: crisp-edges;
  image-rendering: pixelated;
  -ms-interpolation-mode: nearest-neighbor;
}

.placeholder-image {
  opacity: 1;
  z-index: 1;
}

.target-image {
  opacity: 0;
  z-index: 2;
}

.target-image.visible {
  opacity: 1;
}

.target-image.hidden {
  opacity: 0;
}

/* 加载状态 */
.loading-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  z-index: 100;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e0e0e0;
  border-top: 6rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-overlay text {
  color: #333;
  font-size: 28rpx;
  margin-bottom: 15rpx;
  display: block;
  text-align: center;
}

.progress-text {
  color: #4CAF50;
  font-size: 24rpx;
  margin-top: 10rpx;
}

/* 信息覆盖层 */
.info-overlay {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  right: 30rpx;
  z-index: 10;
}

.info-card {
  background: rgba(0, 0, 0, 0.75);
  border-radius: 16rpx;
  padding: 30rpx;
  color: white;
}

.info-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.info-subtitle {
  display: block;
  font-size: 26rpx;
  color: #52c41a;
  margin-bottom: 20rpx;
}

.info-details text {
  display: block;
  font-size: 24rpx;
  color: #cccccc;
  margin-bottom: 8rpx;
}

/* 控制按钮 */
.control-buttons {
  position: absolute;
  bottom: 30rpx;
  right: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  z-index: 10;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.7);
  color: white;
  display: flex;
  justify-content: center;
  align-items: center;
  border: none;
  padding: 0;
  margin: 0;
}

.control-btn::after {
  border: none;
}

.control-btn text {
  font-size: 32rpx;
  font-weight: bold;
}

/* 控制面板 - 简约设计 */
.control-panel {
  background: rgba(255, 255, 255, 0.95);
  padding: 12rpx;
  backdrop-filter: blur(10px);
  border-radius: 12rpx;
  margin: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.selection-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.1);
}

.selection-header-left {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.selection-header-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.selection-title {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.current-selection {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50;
}

/* 年份选择器 - 压缩高分辨率设计 */
.compact-year-section {
  margin-bottom: 12rpx;
  position: relative;
}

/* 年份选择器主体 */
.year-selector {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 249, 250, 0.95) 100%);
  border-radius: 12rpx;
  border: 2rpx solid rgba(76, 175, 80, 0.15);
  padding: 16rpx 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.year-selector:active {
  background: linear-gradient(135deg, rgba(248, 249, 250, 0.95) 0%, rgba(233, 236, 239, 0.95) 100%);
  transform: translateY(1rpx);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

.year-selector-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.year-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.year-value {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.current-year {
  font-size: 32rpx;
  font-weight: 800;
  color: #4CAF50;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.year-dropdown-icon {
  font-size: 24rpx;
  color: #666;
  font-weight: 700;
  transition: transform 0.3s ease;
}

/* 年份选择面板 */
.year-picker-panel {
  position: absolute;
  top: calc(100% + 8rpx);
  left: 0;
  right: 0;
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  z-index: 1000;
  overflow: hidden;
  opacity: 0;
  transform: translateY(-10rpx);
  visibility: hidden;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.year-picker-panel.show {
  opacity: 1;
  transform: translateY(0);
  visibility: visible;
}

.year-picker-panel.hide {
  opacity: 0;
  transform: translateY(-10rpx);
  visibility: hidden;
}

.year-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
}

.year-picker-title {
  font-size: 28rpx;
  font-weight: 700;
}

.year-picker-close {
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
  color: white;
  opacity: 0.9;
}

.year-picker-close:active {
  opacity: 0.7;
}

.year-picker-options {
  max-height: 400rpx;
  overflow-y: auto;
  padding: 12rpx;
}

.year-option {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  background: #f8f9fa;
  transition: all 0.2s ease;
}

.year-option:active {
  background: #e9ecef;
}

.year-option.selected {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.year-option-text {
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.year-option.selected .year-option-text {
  font-weight: 700;
  color: white;
}

.year-option-checkmark {
  font-size: 28rpx;
  font-weight: 700;
  color: white;
}

/* 月份选择器 */
.compact-month-section {
  margin-bottom: 12rpx;
}

.section-label {
  font-size: 24rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.section-label::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 20rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 3rpx;
}

.year-tabs-container {
  position: relative;
}

.compact-tabs {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
  margin-bottom: 3rpx;
}

.compact-tab {
  padding: 12rpx 14rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 249, 250, 0.95) 100%);
  border-radius: 10rpx;
  font-size: 24rpx;
  color: #333;
  text-align: center;
  border: 1rpx solid rgba(76, 175, 80, 0.15);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.compact-tab::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: linear-gradient(135deg, rgba(76, 175, 80, 0.1) 0%, rgba(46, 125, 50, 0.1) 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.compact-tab.active {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  font-weight: 700;
  border-color: transparent;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.4);
  transform: translateY(-1rpx);
  border-width: 1rpx;
}

.compact-tab.active::before {
  opacity: 1;
}

.compact-tab:not(.active):active {
  background: linear-gradient(135deg, rgba(248, 249, 250, 0.95) 0%, rgba(233, 236, 239, 0.95) 100%);
  transform: translateY(0);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}





.auto-play-btn {
  font-size: 24rpx;
  padding: 10rpx 20rpx;
  line-height: 1.3;
  border-radius: 6rpx;
  background: #f0f2f5;
  color: #333;
  border: none;
  flex-shrink: 0;
  font-weight: 500;
}

.auto-play-btn.active {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: white;
  font-weight: bold;
  border-color: transparent;
  box-shadow: 0 3rpx 8rpx rgba(76, 175, 80, 0.3);
}

.auto-play-btn::after {
  border: none;
}

.auto-play-status {
  font-size: 22rpx;
  color: #666;
  flex: 1;
  text-align: right;
  font-weight: 500;
}

/* 时间选择行样式 - 年份和月份并排 */
.time-selection-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.time-selector {
  flex: 1;
  position: relative;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.95) 0%, rgba(248, 249, 250, 0.95) 100%);
  border-radius: 10rpx;
  border: 1rpx solid rgba(76, 175, 80, 0.15);
  padding: 12rpx 14rpx;
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.time-selector:active {
  background: linear-gradient(135deg, rgba(248, 249, 250, 0.95) 0%, rgba(233, 236, 239, 0.95) 100%);
  transform: translateY(1rpx);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

.time-selector-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time-label {
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.time-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.current-time {
  font-size: 26rpx;
  font-weight: 700;
  color: #4CAF50;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.time-dropdown-icon {
  font-size: 20rpx;
  color: #666;
  font-weight: 600;
  transition: transform 0.3s ease;
}

/* 时间选择面板 - 复用年份面板样式，但调整定位 */
